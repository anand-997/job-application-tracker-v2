# JobTracker AI runs fully in guest mode (localStorage) with NO environment variables.
# Deploy to Vercel as-is — no secrets required.
#
# The variables below are OPTIONAL and only needed if you later wire up
# NextAuth login + Vercel KV cloud sync (documented in README "Optional: Cloud Sync").

# NextAuth (optional)
# NEXTAUTH_SECRET=generate-with: openssl rand -base64 32
# NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret

# GitHub OAuth (optional)
# GITHUB_ID=your-github-app-id
# GITHUB_SECRET=your-github-app-secret

# Vercel KV (optional cloud sync)
# KV_REST_API_URL=...
# KV_REST_API_TOKEN=...

# Clearbit logo API needs no key — https://logo.clearbit.com/{domain}
